<Window x:Class="ParkingGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParkingGame"
        mc:Ignorable="d"
        Title="GameWindow" Height="900" Width="1000">
	<Grid>
		<TextBlock Text="COR" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Top"/>
		<Grid x:Name="Game" Width="800" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center">
			<StackPanel Width="800" Height="800" x:Name="question">
				<Label Content="Adja meg mekkora legyen a pálya" Height="200"/>
				<TextBlock x:Name="Gwidth" Text="x" Width="300" Height="200" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
				<TextBlock x:Name="Gheigt" Text="y" Width="300" Height="200" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
				<Button Content="Start" Click="StartGame"/>
			</StackPanel>

		</Grid>
	</Grid>
</Window>
