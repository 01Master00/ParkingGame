<Window x:Class="ParkingGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParkingGame"
        mc:Ignorable="d"
		WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Title="GameWindow" Height="900" Width="1000">

    <Grid>
        <Image Source="/Resources/placeholderbg.png" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Canvas x:Name="Game" MinWidth="800" MinHeight="800" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        
        <Grid x:Name="question" HorizontalAlignment="Center" VerticalAlignment="Top" Background="LightGray">
            <Border BorderBrush="Black" BorderThickness="5" CornerRadius="20" Background="White" Padding="20">
                <StackPanel MaxWidth="800" x:Name="LVLselect">
                    <Label x:Name="Error" Content="Pályák" FontSize="80" HorizontalAlignment="Center" FontWeight="ExtraBold"/>
                    <Canvas x:Name="LevelCanvas" Width="800" Height="800" Background="Transparent">
						<Button Content="Lvl 1" Width="150" Height="150" Canvas.Left="20" Canvas.Top="20" FontSize="40" Tag="1" Click="Level_Click"/>
						<Button Content="Lvl 2" Width="150" Height="150" Canvas.Left="220" Canvas.Top="20" FontSize="40" Tag="2" Click="Level_Click"/>
						<Button Content="Lvl 3" Width="150" Height="150" Canvas.Left="420" Canvas.Top="20" FontSize="40" Tag="3" Click="Level_Click"/>
						<Button Content="Lvl 4" Width="150" Height="150" Canvas.Left="20" Canvas.Top="220" FontSize="40" Tag="4" Click="Level_Click"/>
						<Button Content="Lvl 5" Width="150" Height="150" Canvas.Left="220" Canvas.Top="220" FontSize="40" Tag="5" Click="Level_Click"/>
						<Button Content="Lvl 6" Width="150" Height="150" Canvas.Left="420" Canvas.Top="220" FontSize="40" Tag="6" Click="Level_Click"/>
						<Button Content="Lvl 7" Width="150" Height="150" Canvas.Left="20" Canvas.Top="420" FontSize="40" Tag="7" Click="Level_Click"/>
						<Button Content="Lvl 8" Width="150" Height="150" Canvas.Left="220" Canvas.Top="420" FontSize="40" Tag="8" Click="Level_Click"/>
						<Button Content="Lvl 9" Width="150" Height="150" Canvas.Left="420" Canvas.Top="420" FontSize="40"  Click="Level_Click" Tag="9"/>

                    </Canvas>

                </StackPanel>
            </Border>

        </Grid>
        <Button Content="Vissza" Click="Back_Click" FontSize="30" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,20,0,0" Width="300" Background="red" FontWeight="ExtraBold"/>
    </Grid>
</Window>
